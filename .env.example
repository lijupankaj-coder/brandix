DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seeded local admin account.
BRANDIX_ADMIN_EMAIL="hello@nebulixcloud.com"
BRANDIX_ADMIN_PASSWORD="change-this-local-password"

# Optional future AI provider keys. Local deterministic generation works without these.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Optional Google OAuth login. In Google Cloud Console, add:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
